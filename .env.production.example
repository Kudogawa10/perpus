# .env.production.example for MyPerpus Railway Deployment
# Copy to .env and customize for production

APP_NAME=MyPerpus
APP_ENV=production
# Run once: php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_URL=https://myperpus-productions.up.railway.app

LOG_CHANNEL=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
# Filled by docker/start.sh from Railway MYSQLHOST/MYSQL_URL
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
MYSQL_URL=
MYSQLHOST=
MYSQLPORT=
MYSQLDATABASE=
MYSQLUSER=
MYSQLPASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

REDIS_CLIENT=predis
REDIS_URL=
REDISHOST=
REDISUSER=
REDISPORT=6379
REDISPASSWORD=
REDIS_HOST=
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_EMAIL=admin@perpus.com
ADMIN_PASSWORD=SecurePass123

# Railway specific
RUN_MIGRATIONS=true
RUN_SEEDERS=true
PORT=8080

# Security
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,::1,myperpus-production.up.railway.app
SESSION_DOMAIN=

# Perpus settings (from database after seeding)
PERPUS_NAMA="Perpustakaan Digital"
PERPUS_ALAMAT="Jl. Contoh No.123"
PERPUS_TELEPON="021-1234567"
