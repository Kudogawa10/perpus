# .env.production.example for MyPerpus Railway Deployment
# Copy to .env and customize for production

APP_NAME=MyPerpus
APP_ENV=production
APP_KEY=  # Run: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://myperpus-productions.up.railway.app

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=  # Railway DB plugin auto-fills
DB_PORT=3306
DB_DATABASE=  # Railway auto-fills
DB_USERNAME=  #Railway auto-fills
DB_PASSWORD=  #Railway auto-fills

BROADCAST_CONNECTION=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_EMAIL=admin@perpus.com
ADMIN_PASSWORD=SecurePass123

# Railway specific
RUN_MIGRATIONS=true
PORT=8080

# Security
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,::1,myperpus-production.up.railway.app
SESSION_DOMAIN=railway.app

# Perpus settings (from database after seeding)
PERPUS_NAMA="Perpustakaan Digital"
PERPUS_ALAMAT="Jl. Contoh No.123"
PERPUS_TELEPON="021-1234567"
